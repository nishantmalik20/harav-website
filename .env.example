# ───────────── Resend (email) ─────────────
RESEND_API_KEY=
RESEND_FROM="Harav Salon & Spa <bookings@haravsalonspa.ca>"
BOOKINGS_NOTIFY_EMAIL=contact@haravsalonspa.ca

# ───────────── Stripe (deposit) ─────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ───────────── Supabase (bookings + admin auth) ─────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated emails allowed into /admin (e.g. khushi@haravsalonspa.ca)
ADMIN_EMAILS=

# ───────────── Site ─────────────
NEXT_PUBLIC_SITE_URL=https://haravsalonspa.ca
