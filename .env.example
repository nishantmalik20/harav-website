# ───────────── Resend (email) ─────────────
RESEND_API_KEY=
RESEND_FROM="Harav Salon & Spa <contact@haravsalonspa.ca>"
BOOKINGS_NOTIFY_EMAIL=contact@haravsalonspa.ca
# Where product order notifications go (falls back to BOOKINGS_NOTIFY_EMAIL)
ORDERS_NOTIFY_EMAIL=contact@haravsalonspa.ca

# ───────────── Stripe (booking deposit + product checkout) ─────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ───────────── Boutique (Stripe product store) ─────────────
# Leave blank to keep the shop in preview (no cart / no checkout).
# Set to "true" only AFTER Stripe is set up and `npm run stripe:sync` has run.
NEXT_PUBLIC_STORE_ENABLED=

# ───────────── Supabase (bookings + admin auth) ─────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated emails allowed into /admin (e.g. khushi@haravsalonspa.ca)
ADMIN_EMAILS=

# ───────────── Site ─────────────
NEXT_PUBLIC_SITE_URL=https://haravsalonspa.ca
